    <ImplicitUsings>enable</ImplicitUsings>
    <AvaloniaVersion>12.0.4</AvaloniaVersion>
    <AvaloniaDataGridVersion>12.0.0</AvaloniaDataGridVersion>
    <Version>2.0.47</Version>
    <InformationalVersion>$(Version)</InformationalVersion>
  </PropertyGroup>
</Project>
