<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:CNC.Controls.Avalonia.Converters"
             xmlns:views="using:CNC.Controls.Avalonia.Views"
             xmlns:local="using:CNC.Controls.Probing"
             x:Class="CNC.Controls.Probing.EdgeFinderIntControl"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             >

  <UserControl.Resources>

    <conv:LogicalNotConverter x:Key="IsNotRunningConverter"/>
    <conv:EnumValueToBooleanConverter x:Key="EnumToEdgeConverter"/>
    <conv:BoolToVisibleConverter x:Key="ToVisibleConverter"/>
    <local:EdgeZProbeVisibleConverter x:Key="ZProbeIsVisibleConverter"/>
    <local:LogicalAndConverter x:Key="LogicalAndConverter"/>
  </UserControl.Resources>

  <Grid>
    <StackPanel Margin="5" Spacing="4">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <local:CsSelectControl/>
        <GroupBox Header="Workpiece" Classes="form-section">
          <StackPanel Spacing="4">

            <views:NumericField Classes="form-field" Label="Height:" Unit="{Binding Grbl.Unit}" Value="{Binding WorkpieceHeight, Mode=TwoWay}" IsEnabled="{Binding ProbeZ}" Format="0.000" PreviewText="10.000"/>

            <views:NumericField Classes="form-field" Label="Edge offset:" Unit="{Binding Grbl.Unit}" Value="{Binding WorkpieceXYEdgeOffset, Mode=TwoWay}" Format="0.000" PreviewText="10.000" ToolTip.Tip="Set to 0 to use 0.5 x probe/tool diameter">
                <views:NumericField.IsEnabled>
                  <MultiBinding Converter="{StaticResource LogicalAndConverter}">
                    <Binding Path="ProbeZ"/>
                    <Binding Path="ProbeVerticalEdge"/>
                  </MultiBinding>
                </views:NumericField.IsEnabled>
            </views:NumericField>

          </StackPanel>
        </GroupBox>
      </StackPanel>

      <StackPanel Orientation="Horizontal" Margin="4,0" Spacing="16">
        <CheckBox Content="Probe Z" IsChecked="{Binding ProbeZ, Mode=TwoWay}"
                  IsEnabled="{Binding #ProbeZRadio.IsChecked, Converter={StaticResource IsNotRunningConverter}}"/>
        <CheckBox Content="Preview" IsChecked="{Binding PreviewEnable, Mode=TwoWay}"/>
      </StackPanel>

      <Grid ColumnDefinitions="Auto,*" Margin="4,0">

        <Grid Grid.Column="0" Margin="0,10" x:Name="ActionGrid" ToolTip.Tip="Click edge, corner or center to select probing action."
              Width="180" Height="180"
              RowDefinitions="55,55,55" ColumnDefinitions="55,55,55">
          <local:ProbeEdgeButton Edge="D" GroupName="edgeInt" Theme="{StaticResource EdgeFlagRadioTheme}"
                                 SelectedEdge="{Binding ProbeEdge, Mode=TwoWay}" ProbeZ="{Binding ProbeZ}"
                                 ImageUri="avares://CNC.Controls.Probing.Avalonia/Views/Resources/cornerID.png"
                                 MarkerMargin="35,35,0,0"/>

          <local:ProbeEdgeButton Grid.Column="1" Edge="CD" GroupName="edgeInt" Theme="{StaticResource EdgeFlagRadioTheme}"
                                 SelectedEdge="{Binding ProbeEdge, Mode=TwoWay}" ProbeZ="{Binding ProbeZ}"
                                 ImageUri="avares://CNC.Controls.Probing.Avalonia/Views/Resources/edgeICD.png"
                                 MarkerMargin="0,35,0,0"/>

          <local:ProbeEdgeButton Grid.Column="2" Edge="C" GroupName="edgeInt" Theme="{StaticResource EdgeFlagRadioTheme}"
                                 SelectedEdge="{Binding ProbeEdge, Mode=TwoWay}" ProbeZ="{Binding ProbeZ}"
                                 ImageUri="avares://CNC.Controls.Probing.Avalonia/Views/Resources/cornerIC.png"
                                 MarkerMargin="0,35,35,0"/>

          <local:ProbeEdgeButton Grid.Row="1" Edge="AD" GroupName="edgeInt" Theme="{StaticResource EdgeFlagRadioTheme}"
                                 SelectedEdge="{Binding ProbeEdge, Mode=TwoWay}" ProbeZ="{Binding ProbeZ}"
                                 ImageUri="avares://CNC.Controls.Probing.Avalonia/Views/Resources/edgeIAD.png"
                                 MarkerMargin="35,0,0,0"/>

          <local:ProbeEdgeButton x:Name="ProbeZRadio" Grid.Row="1" Grid.Column="1" Edge="Z" GroupName="edgeInt" Theme="{StaticResource EdgeFlagRadioTheme}"
                                 SelectedEdge="{Binding ProbeEdge, Mode=TwoWay}" ProbeZ="{Binding ProbeZ}"
                                 ImageUri="avares://CNC.Controls.Probing.Avalonia/Views/Resources/edgeZ.png"/>

          <local:ProbeEdgeButton Grid.Row="1" Grid.Column="2" Edge="CB" GroupName="edgeInt" Theme="{StaticResource EdgeFlagRadioTheme}"
                                 SelectedEdge="{Binding ProbeEdge, Mode=TwoWay}" ProbeZ="{Binding ProbeZ}"
                                 ImageUri="avares://CNC.Controls.Probing.Avalonia/Views/Resources/edgeIBC.png"
                                 MarkerMargin="0,0,35,0"/>

          <local:ProbeEdgeButton Grid.Row="2" Edge="A" GroupName="edgeInt" Theme="{StaticResource EdgeFlagRadioTheme}"
                                 SelectedEdge="{Binding ProbeEdge, Mode=TwoWay}" ProbeZ="{Binding ProbeZ}"
                                 ImageUri="avares://CNC.Controls.Probing.Avalonia/Views/Resources/cornerIA.png"
                                 MarkerMargin="35,0,0,35"/>

          <local:ProbeEdgeButton Grid.Row="2" Grid.Column="1" Edge="AB" GroupName="edgeInt" Theme="{StaticResource EdgeFlagRadioTheme}"
                                 SelectedEdge="{Binding ProbeEdge, Mode=TwoWay}" ProbeZ="{Binding ProbeZ}"
                                 ImageUri="avares://CNC.Controls.Probing.Avalonia/Views/Resources/edgeIAB.png"
                                 MarkerMargin="0,0,0,35"/>

          <local:ProbeEdgeButton Grid.Row="2" Grid.Column="2" Edge="B" GroupName="edgeInt" Theme="{StaticResource EdgeFlagRadioTheme}"
                                 SelectedEdge="{Binding ProbeEdge, Mode=TwoWay}" ProbeZ="{Binding ProbeZ}"
                                 ImageUri="avares://CNC.Controls.Probing.Avalonia/Views/Resources/cornerIB.png"
                                 MarkerMargin="0,0,35,35"/>

        </Grid>

        <GroupBox Grid.Column="1" Header="Preview" Classes="form-section"
                  IsVisible="{Binding PreviewEnable, Converter={StaticResource ToVisibleConverter}}">
          <TextBox IsReadOnly="True" Text="{Binding PreviewText, Mode=OneWay}" TextWrapping="NoWrap"
                   FontSize="10" FontFamily="Verdana"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
        </GroupBox>

      </Grid>
    </StackPanel>

    <Grid Classes="action-footer" Margin="5,0,5,5" ColumnDefinitions="*,*" ColumnSpacing="4" VerticalAlignment="Bottom">
      <Button Grid.Column="0" Classes="action-footer-button" Content="Start"
              IsEnabled="{Binding Grbl.IsJobRunning, Converter={StaticResource IsNotRunningConverter}}"
              Click="OnStartClick"/>
      <Button Grid.Column="1" Classes="action-footer-button" Content="Stop"
              IsEnabled="{Binding Grbl.IsJobRunning}"
              Click="OnStopClick"/>
    </Grid>

  </Grid>

</UserControl>
