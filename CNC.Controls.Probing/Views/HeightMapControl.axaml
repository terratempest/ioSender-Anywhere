<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:CNC.Controls.Avalonia.Converters"
             xmlns:views="using:CNC.Controls.Avalonia.Views"
             xmlns:local="using:CNC.Controls.Probing"
             xmlns:viewer="using:CNC.GCodeViewer.Avalonia.Views"
             x:Class="CNC.Controls.Probing.HeightMapControl"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800">
  <UserControl.Resources>
    <conv:LogicalNotConverter x:Key="IsNotRunningConverter"/>
  </UserControl.Resources>
  <Grid TextElement.FontSize="12" RowDefinitions="*,Auto" RowSpacing="8">
    <ScrollViewer>
      <Grid ColumnDefinitions="270,315,*" ColumnSpacing="25" Margin="5">
        <StackPanel Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="4">
          <GroupBox Classes="form-section"
            Header="Area to probe" 
            Padding="0"
            >
            
            <Grid Margin="4" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="4*,5*" RowSpacing="4" ColumnSpacing="8">
              
              <views:NumericField Classes="form-field" Label="X:" 
                Unit="{Binding Grbl.Unit}" 
                Value="{Binding HeightMap.MinX, Mode=TwoWay}" 
                Format="-###0.0##" PreviewText="0000.0 mm"/>
              <views:NumericField Grid.Column="1" Classes="form-field" Label="Width:" 
                Unit="{Binding Grbl.Unit}" 
                Value="{Binding HeightMap.Width, Mode=TwoWay}" 
                Format="-###0.0##" PreviewText="0000.0 mm"/>
              <views:NumericField Grid.Row="1" Classes="form-field" Label="Y:" 
                Unit="{Binding Grbl.Unit}" 
                Value="{Binding HeightMap.MinY, 
                Mode=TwoWay}" Format="-###0.0##" PreviewText="0000.0 mm"/>
              <views:NumericField Grid.Row="1" Grid.Column="1" Classes="form-field" Label="Height:" 
                Unit="{Binding Grbl.Unit}" 
                Value="{Binding HeightMap.Height, Mode=TwoWay}" 
                Format="-###0.0##" PreviewText="0000.0 mm"/>

              <Button Grid.Row="2" Grid.ColumnSpan="2" Content="Set from program limits" 
                IsEnabled="{Binding Grbl.IsFileLoaded}" 
                Click="OnLimitsClick"
                HorizontalAlignment="Stretch" 
                HorizontalContentAlignment="Center"/>
            </Grid>
          </GroupBox>

          <GroupBox Header="Gridsize" Classes="form-section">
            <StackPanel Spacing="4">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <StackPanel Grid.Column="0" Spacing="4">
                  <views:NumericField Classes="form-field" Label="X:" Unit="{Binding Grbl.Unit}" Value="{Binding HeightMap.GridSizeX, Mode=TwoWay}" Format="0.000" PreviewText="5.000"/>
                  <views:NumericField Classes="form-field" Label="Y:" Unit="{Binding Grbl.Unit}" Value="{Binding HeightMap.GridSizeY, Mode=TwoWay}" Format="0.000" PreviewText="5.000"/>
                </StackPanel>
                <CheckBox Grid.Column="1" Content="Lock" VerticalAlignment="Center" IsChecked="{Binding HeightMap.GridSizeLockXY, Mode=TwoWay}"/>
              </Grid>
            </StackPanel>
          </GroupBox>
          <StackPanel Margin="4,0" Spacing="-6">
            <CheckBox Content="Pause before probing" IsChecked="{Binding HeightMap.AddPause, Mode=TwoWay}"/>
            <CheckBox Content="Set Z = 0 at X0Y0" IsChecked="{Binding HeightMap.SetToolOffset, Mode=TwoWay}"/>
          </StackPanel>
          <local:CsSelectControl IsEnabled="{Binding HeightMap.SetToolOffset}"/>
        </StackPanel>

        <GroupBox Grid.Column="1" Header="Preview" Classes="form-section" Height="335" HorizontalAlignment="Stretch" VerticalAlignment="Top">
          <viewer:HeightMapPreviewControl x:Name="Preview3D"/>
        </GroupBox>

      </Grid>

    </ScrollViewer>

    <Grid Grid.Row="1" Classes="action-footer" Margin="5,0,5,5" ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="4">
      <Button Grid.Column="0" Classes="action-footer-button" Content="Start"
              IsEnabled="{Binding Grbl.IsJobRunning, Converter={StaticResource IsNotRunningConverter}}"
              Click="OnStartClick"/>
      <Button Grid.Column="1" Classes="action-footer-button" Content="Probe" IsEnabled="{Binding IsPaused}" Click="OnProbeClick"/>
      <Button Grid.Column="2" Classes="action-footer-button" Content="Stop" IsEnabled="{Binding Grbl.IsJobRunning}" Click="OnStopClick"/>
      <Button Grid.Column="3" Classes="action-footer-button" Content="Load"
              IsEnabled="{Binding Grbl.IsJobRunning, Converter={StaticResource IsNotRunningConverter}}"
              Click="OnLoadClick"/>
      <Button Grid.Column="4" Classes="action-footer-button" Content="Save"
              IsEnabled="{Binding Grbl.IsJobRunning, Converter={StaticResource IsNotRunningConverter}}"
              Click="OnSaveClick"/>
      <Button Grid.Column="5" Classes="action-footer-button" Content="Apply" IsEnabled="{Binding HeightMap.CanApply}" Click="OnApplyClick"/>
    </Grid>
  </Grid>
</UserControl>
