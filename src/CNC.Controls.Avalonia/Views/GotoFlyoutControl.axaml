<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:CNC.Controls.Avalonia.Views"
             x:Class="CNC.Controls.Avalonia.Views.GotoFlyoutControl"
             Focusable="False"
             MinHeight="118" MinWidth="200"
             IsVisible="False">
  <Border Classes="flyout-panel">
    <Grid>
      <views:GotoBaseControl Margin="15,15,0,8"/>
      <Button Classes="flyout-close" Content="×" HorizontalAlignment="Right" Margin="0,0,5,0"
              VerticalAlignment="Top" Click="OnCloseClick"/>
    </Grid>
  </Border>
</UserControl>
