<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:CNC.Controls.Avalonia.Views"
             x:Class="CNC.Controls.Avalonia.Views.OutlineControl"
             Height="125" Width="250">
  <Border Classes="panel-chrome" BorderThickness="1" Padding="4" Width="250" Height="125">
    <StackPanel>
      <TextBlock Text="Outline" FontWeight="Bold" Margin="0,0,0,4"/>
      <views:OutlineBaseControl/>
    </StackPanel>
  </Border>
</UserControl>
