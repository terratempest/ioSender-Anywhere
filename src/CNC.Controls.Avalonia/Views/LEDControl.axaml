<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CNC.Controls.Avalonia.Views.LEDControl"
             MaxHeight="28" MaxWidth="140">
  <StackPanel Orientation="Horizontal" Height="28">
    <Border BorderBrush="LightGray" BorderThickness="1" Width="12" Height="12" Margin="2,0,0,0" VerticalAlignment="Center">
      <Panel x:Name="btnLED" Width="10" Height="10"/>
    </Border>
    <TextBlock x:Name="labelLED"
               Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
               Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12"/>
  </StackPanel>
</UserControl>
