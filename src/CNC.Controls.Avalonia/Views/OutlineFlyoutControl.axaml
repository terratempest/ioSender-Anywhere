<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:CNC.Controls.Avalonia.Views"
             x:Class="CNC.Controls.Avalonia.Views.OutlineFlyoutControl"
             Focusable="False"
             MaxWidth="300"
             IsVisible="False"
             Loaded="OnLoaded">
  <Border Classes="flyout-panel" Height="120">
    <Grid>
      <views:OutlineBaseControl Margin="0,15,0,0"/>
      <Button Classes="flyout-close" Content="×" HorizontalAlignment="Right" Margin="0,0,5,0"
              VerticalAlignment="Top" Click="OnCloseClick"/>
    </Grid>
  </Border>
</UserControl>
