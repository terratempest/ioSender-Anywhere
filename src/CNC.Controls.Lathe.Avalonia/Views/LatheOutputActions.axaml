<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:CNC.Localization.Avalonia"
             x:Class="CNC.Controls.Lathe.LatheOutputActions">
  <StackPanel Orientation="Horizontal" Spacing="8">
    <Button x:Name="BtnCalculate" Content="Calculate" Width="90" Click="OnCalculateClick"/>
    <Button x:Name="BtnLoadProgram" Content="Load in program" MinWidth="110" Click="OnLoadProgramClick"
            loc:Localize.Key="ioSender.lathe.btn_loadProgram" loc:Localize.Fallback="Load in program"/>
    <Button x:Name="BtnSaveFile" Content="Save as..." MinWidth="90" Click="OnSaveFileClick"
            loc:Localize.Key="ioSender.lathe.btn_saveFile" loc:Localize.Fallback="Save as..."/>
    <TextBlock Classes="warning-text" VerticalAlignment="Center"
               loc:Localize.Key="ioSender.lathe.str_warning" loc:Localize.Fallback="Warning! Use with care - only lightly tested!"/>
  </StackPanel>
</UserControl>
