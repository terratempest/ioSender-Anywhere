<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ioSender.Views.CameraWindow"
        Title="Camera"
        Width="640" Height="520"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="8">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBlock VerticalAlignment="Center" Text="Device"/>
      <ComboBox x:Name="DeviceCombo" Width="120"/>
      <Button x:Name="RefreshBtn" Content="Refresh" Padding="10,4"/>
      <Button x:Name="StartBtn" Content="Start" Padding="10,4"/>
      <Button x:Name="StopBtn" Content="Stop" Padding="10,4" IsEnabled="False"/>
    </StackPanel>
    <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom" Margin="0,8,0,0" TextWrapping="Wrap"/>
    <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
      <Image x:Name="PreviewImage" Stretch="Uniform"/>
    </Border>
  </DockPanel>
</Window>
