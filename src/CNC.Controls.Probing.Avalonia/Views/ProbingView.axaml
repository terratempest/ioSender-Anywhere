<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="using:CNC.Controls.Avalonia.Converters"
             xmlns:controls="using:CNC.Controls.Avalonia.Controls"
             xmlns:local="using:CNC.Controls.Probing"
             xmlns:loc="using:CNC.Localization.Avalonia"
             mc:Ignorable="d"
             d:DesignHeight="515" d:DesignWidth="900"
             x:Class="CNC.Controls.Probing.ProbingView">

  <UserControl.Resources>
    <conv:LogicalNotConverter x:Key="IsNotRunningConverter"/>
    <local:ProbingMacroActiveBrushConverter x:Key="MacroActiveBrushConverter"/>
  </UserControl.Resources>

  <Grid>
  <DockPanel x:Name="ProbingRoot" Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
    <DockPanel x:Name="SidebarHost" DockPanel.Dock="Left" Margin="5,5,5,0" Width="240"
               HorizontalAlignment="Left" VerticalAlignment="Stretch">
      <StackPanel DockPanel.Dock="Top" Spacing="5">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBlock Text="Profile:" VerticalAlignment="Center" Width="48" TextAlignment="Right"/>
          <ComboBox x:Name="ProfileCombo" Width="155" Height="22"
                    ItemsSource="{Binding Profiles}"
                    SelectedItem="{Binding Profile, Mode=TwoWay}"
                    DisplayMemberBinding="{Binding Name}"/>
          <Button x:Name="ProfileMenuBtn" Content="..." Width="22" Height="22" Click="OnProfileMenuClick"/>
        </StackPanel>

        <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" Padding="6" CornerRadius="2">
          <StackPanel Spacing="4">
            <TextBlock Text="Probe tip/tool" FontWeight="SemiBold"/>
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">
              <TextBlock Grid.Column="0" Text="Diameter:" VerticalAlignment="Center" Margin="0,0,6,0"/>
              <controls:NumericTextBox Grid.Column="1" Value="{Binding ProbeDiameter, Mode=TwoWay}" Format="0.###"/>
            </Grid>
          </StackPanel>
        </Border>

        <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" Padding="6" CornerRadius="2">
          <StackPanel Spacing="4">
            <TextBlock Text="Touch plate/fixture height" FontWeight="SemiBold"/>
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Touch plate:" VerticalAlignment="Center" Margin="0,0,6,4"/>
              <controls:NumericTextBox Grid.Row="0" Grid.Column="1" Value="{Binding TouchPlateHeight, Mode=TwoWay}" Format="0.###" Margin="0,0,0,4"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Fixture:" VerticalAlignment="Center" Margin="0,0,6,0"/>
              <controls:NumericTextBox Grid.Row="1" Grid.Column="1" Value="{Binding FixtureHeight, Mode=TwoWay}" Format="0.###"/>
            </Grid>
          </StackPanel>
        </Border>

        <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" Padding="6" CornerRadius="2">
          <StackPanel Spacing="4">
            <TextBlock Text="Probing distances and speed" FontWeight="SemiBold"/>
            <StackPanel Spacing="3">
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="Rapids feed:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <controls:NumericTextBox Grid.Column="1" Value="{Binding RapidsFeedRate, Mode=TwoWay}" Format="####0"/>
              </Grid>
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="Search feed:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <controls:NumericTextBox Grid.Column="1" Value="{Binding ProbeFeedRate, Mode=TwoWay}" Format="####0"/>
              </Grid>
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="Latch feed:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <controls:NumericTextBox Grid.Column="1" Value="{Binding LatchFeedRate, Mode=TwoWay}" Format="####0"/>
              </Grid>
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="Probe distance:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <controls:NumericTextBox Grid.Column="1" Value="{Binding ProbeDistance, Mode=TwoWay}" Format="0.###"/>
              </Grid>
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="Latch distance:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <controls:NumericTextBox Grid.Column="1" Value="{Binding LatchDistance, Mode=TwoWay}" Format="0.###"/>
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" Padding="6" CornerRadius="2">
          <StackPanel Spacing="4">
            <TextBlock Text="Probing clearances" FontWeight="SemiBold"/>
            <StackPanel Spacing="3">
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="XY clearance:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <controls:NumericTextBox Grid.Column="1" Value="{Binding XYClearance, Mode=TwoWay}" Format="0.###"/>
              </Grid>
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="Offset:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <controls:NumericTextBox Grid.Column="1" Value="{Binding Offset, Mode=TwoWay}" Format="0.###"/>
              </Grid>
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="Depth:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <controls:NumericTextBox Grid.Column="1" Value="{Binding Depth, Mode=TwoWay}" Format="0.###"/>
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" Padding="6" CornerRadius="2">
          <StackPanel Spacing="4">
            <TextBlock Text="Probe/touchplate XY offsets" FontWeight="SemiBold"/>
            <Grid ColumnDefinitions="Auto,*,Auto,*">
              <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center"/>
              <controls:NumericTextBox Grid.Column="1" Value="{Binding ProbeOffsetX, Mode=TwoWay}" Format="0.###"/>
              <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center"/>
              <controls:NumericTextBox Grid.Column="3" Value="{Binding ProbeOffsetY, Mode=TwoWay}" Format="0.###"/>
            </Grid>
            <CheckBox Content="Is touch plate" IsChecked="{Binding TouchPlateIsXY, Mode=TwoWay}"/>
          </StackPanel>
        </Border>

        <TextBlock Text="{Binding Position}" Height="25"/>
      </StackPanel>
    </DockPanel>

    <StackPanel DockPanel.Dock="Right" Margin="0,10,0,0" Width="635"
                HorizontalAlignment="Left" VerticalAlignment="Top">
      <TabControl x:Name="WizardTabs" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                  SelectionChanged="OnTabSelectionChanged">
        <TabItem Header="Tool length offset">
          <local:ToolLengthControl/>
        </TabItem>
        <TabItem Header="Edge finder, external">
          <local:EdgeFinderControl/>
        </TabItem>
        <TabItem Header="Edge finder, internal">
          <local:EdgeFinderIntControl/>
        </TabItem>
        <TabItem Header="Rotation">
          <local:RotationControl/>
        </TabItem>
        <TabItem Header="Center finder">
          <local:CenterFinderControl/>
        </TabItem>
        <TabItem Header="Height map">
          <local:HeightMapControl/>
        </TabItem>
      </TabControl>
      <Grid Margin="0,2,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="125"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{Binding Instructions}" TextWrapping="Wrap" Height="70" Margin="0,2,0,0"/>
        <StackPanel Grid.Column="1" Margin="5,5,0,0" Spacing="5">
          <ComboBox x:Name="MacroCombo" Width="120" Height="22"
                    ItemsSource="{Binding Macro.Macros}"
                    SelectedItem="{Binding Macro.SelectedMacro, Mode=TwoWay}"
                    DisplayMemberBinding="{Binding Name}"
                    IsEnabled="{Binding Grbl.IsJobRunning, Converter={StaticResource IsNotRunningConverter}}"/>
          <Button x:Name="MacroButton" Content="Pre/post macros" HorizontalAlignment="Left" Height="25" Width="120"
                  ToolTip.Tip="{Binding Macro.ActiveMacroName}"
                  Background="{Binding Macro.SelectedMacro, Converter={StaticResource MacroActiveBrushConverter}}"
                  IsEnabled="{Binding Grbl.IsJobRunning, Converter={StaticResource IsNotRunningConverter}}"
                  Click="OnMacroButtonClick"/>
        </StackPanel>
      </Grid>
      <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Classes="warning-text"
                 Text="Warning! Use with care - incorrect parameters may damage your probe!"
                 loc:Localize.Key="CNC.Controls.Probing.probingview.str_probeWarning"
                 loc:Localize.Fallback="Warning! Use with care - incorrect parameters may damage your probe!"/>
    </StackPanel>
  </DockPanel>

  <Border x:Name="DisconnectedOverlay" Classes="disconnected-overlay"
          IsVisible="False" ZIndex="20">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Margin="24">
      <TextBlock FontSize="16" FontWeight="SemiBold" Classes="overlay-message"
                 loc:Localize.Key="ioSender.probing.str_notConnectedTitle" loc:Localize.Fallback="Not connected to controller"/>
      <TextBlock TextWrapping="Wrap" MaxWidth="420" Classes="overlay-message" Opacity="0.9"
                 loc:Localize.Key="ioSender.probing.str_notConnectedBody"
                 loc:Localize.Fallback="Connect from the toolbar before running probing cycles."/>
    </StackPanel>
  </Border>
  </Grid>
</UserControl>
