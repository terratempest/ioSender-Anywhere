<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Deeper dark surfaces; still avoids pure black / pure white. -->
  <ResourceDictionary.ThemeDictionaries>
  <ResourceDictionary x:Key="Dark">
    <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#141414"/>
    <SolidColorBrush x:Key="ThemeForegroundBrush" Color="#C8C8C8"/>
    <SolidColorBrush x:Key="ThemeControlLowBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ThemeControlMidBrush" Color="#222222"/>
    <SolidColorBrush x:Key="ThemeControlHighBrush" Color="#2C2C2C"/>
    <SolidColorBrush x:Key="ThemeControlHighlightLowBrush" Color="#2E2E2E"/>
    <SolidColorBrush x:Key="ThemeControlHighlightMidBrush" Color="#353535"/>
    <SolidColorBrush x:Key="ThemeControlHighlightHighBrush" Color="#3D3D3D"/>
    <SolidColorBrush x:Key="ThemeBorderLowBrush" Color="#333333"/>
    <SolidColorBrush x:Key="ThemeBorderMidBrush" Color="#444444"/>
    <SolidColorBrush x:Key="ThemeBorderHighBrush" Color="#5A5A5A"/>
    <SolidColorBrush x:Key="IoSenderReadOnlyBrush" Color="#222222"/>
    <SolidColorBrush x:Key="IoSenderOverlayBrush" Color="#AA000000"/>
  </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
