<UserControl xmlns="https://github.com/avaloniaui"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:app="using:CNC.App"

             x:Class="CNC.Controls.Config.AppKeyboardConfigPanel"

             Width="310">

  <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}"

          BorderThickness="1" Padding="8" CornerRadius="2">

    <StackPanel Spacing="6">

      <TextBlock Text="Keyboard mappings" FontWeight="SemiBold"/>

      <TextBlock Text="Jog mode:"/>

      <ComboBox x:Name="JogModeCombo" HorizontalAlignment="Stretch"
                SelectionChanged="OnJogModeChanged"/>

      <TextBlock x:Name="KeyMapPathText" TextWrapping="Wrap" FontSize="11" Opacity="0.85"/>

      <StackPanel Orientation="Horizontal" Spacing="6">

        <Button x:Name="SaveKeyMapBtn" Content="Save mappings" MinWidth="100" Click="OnSaveKeyMapClick"/>

        <Button x:Name="LoadKeyMapBtn" Content="Load mappings" MinWidth="100" Click="OnLoadKeyMapClick"/>

      </StackPanel>

      <TextBlock x:Name="KeyMapStatusText" TextWrapping="Wrap" FontSize="11" Opacity="0.85"/>

    </StackPanel>

  </Border>

</UserControl>

