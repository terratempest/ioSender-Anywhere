<UserControl xmlns="https://github.com/avaloniaui"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:cnc="using:CNC.Controls.Avalonia.Views"

             x:Class="CNC.Controls.Config.AppCameraConfigPanel"

             Width="310">

  <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}"

          BorderThickness="1" Padding="8" CornerRadius="2">

    <StackPanel Spacing="4">

      <TextBlock Text="Camera" FontWeight="SemiBold"/>

      <cnc:NumericField Label="Device index:" Format="#0"

                        Value="{Binding Camera.DeviceIndex, Mode=TwoWay}"/>

      <cnc:NumericField Label="Width:" Unit="px" Format="####0"

                        Value="{Binding Camera.CaptureWidth, Mode=TwoWay}"/>

      <cnc:NumericField Label="Height:" Unit="px" Format="####0"

                        Value="{Binding Camera.CaptureHeight, Mode=TwoWay}"/>

      <CheckBox Content="Initial move to spindle"

                IsChecked="{Binding Camera.InitialMoveToSpindle, Mode=TwoWay}" Margin="0,4,0,0"/>

      <CheckBox Content="Confirm move"

                IsChecked="{Binding Camera.ConfirmMove, Mode=TwoWay}"/>

      <cnc:NumericField Label="X offset:"

                        Value="{Binding Camera.XOffset, Mode=TwoWay}"/>

      <cnc:NumericField Label="Y offset:"

                        Value="{Binding Camera.YOffset, Mode=TwoWay}"/>

      <Grid ColumnDefinitions="90,*" Margin="0,2,0,0">

        <TextBlock Grid.Column="0" Text="Offset motion:" HorizontalAlignment="Right" VerticalAlignment="Center"/>

        <ComboBox Grid.Column="1" Margin="4,0,0,0" Width="120" HorizontalAlignment="Left"

                  ItemsSource="{Binding Camera.MoveModes}"

                  SelectedItem="{Binding Camera.MoveMode, Mode=TwoWay}"/>

      </Grid>

      <Button x:Name="GetPositionBtn" Content="Get current position" Margin="0,4,0,0"

              HorizontalAlignment="Left" Click="OnGetPositionClick"/>

      <TextBlock Text="Capture size applies when camera is opened."

                 FontSize="11" Opacity="0.75" TextWrapping="Wrap"/>

    </StackPanel>

  </Border>

</UserControl>

