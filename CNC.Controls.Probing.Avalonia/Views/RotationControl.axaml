<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:CNC.Controls.Avalonia.Converters"
             xmlns:local="using:CNC.Controls.Probing"
             x:Class="CNC.Controls.Probing.RotationControl">
  <UserControl.Resources>
    <conv:LogicalNotConverter x:Key="IsNotRunningConverter"/>
    <conv:EnumValueToBooleanConverter x:Key="EnumToEdgeConverter"/>
    <conv:BoolToVisibleConverter x:Key="ToVisibleConverter"/>
    <local:OriginToX0Y0Converter x:Key="UseX0Y0Converter"/>
    <local:OriginToCurrentPosConverter x:Key="UseXYConverter"/>
    <ControlTheme x:Key="RotFlagRadioTheme" TargetType="RadioButton">
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Width" Value="80"/>
      <Setter Property="Height" Value="80"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Opacity" Value="0.5"/>
      <Style Selector="^:checked">
        <Setter Property="Opacity" Value="1"/>
      </Style>
    </ControlTheme>
  </UserControl.Resources>
  <Grid>
    <StackPanel Margin="5" Spacing="4">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" Padding="6" CornerRadius="2" Width="280">
          <StackPanel Spacing="4">
            <TextBlock Text="Workpiece offset" FontWeight="SemiBold"/>
            <CheckBox Content="Determine X0,Y0 for right angled workpiece"
                      ToolTip.Tip="Adds a probe point on the left edge."
                      IsChecked="{Binding AddAction, Mode=TwoWay}"/>
            <local:CsSelectControl IsEnabled="{Binding AddAction}"/>
          </StackPanel>
        </Border>
        <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" Padding="6" CornerRadius="2"
                ToolTip.Tip="Click to select rotation center relative to job; if not selected X0,Y0 is used.">
          <StackPanel Spacing="4">
            <TextBlock Text="Rotation center" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <local:OriginPickerControl Value="{Binding Origin, Mode=TwoWay}"
                                         IsEnabled="{Binding Grbl.IsFileLoaded}"/>
              <StackPanel Spacing="4" VerticalAlignment="Center">
                <CheckBox Content="Use X,Y" IsEnabled="{Binding Grbl.IsFileLoaded}"
                          IsChecked="{Binding Origin, Mode=TwoWay, Converter={StaticResource UseXYConverter}}"/>
                <CheckBox Content="Use X0,Y0" IsEnabled="{Binding Grbl.IsFileLoaded}"
                          IsChecked="{Binding Origin, Mode=TwoWay, Converter={StaticResource UseX0Y0Converter}}"/>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
      <CheckBox Content="Preview" Margin="15,0,0,0" IsChecked="{Binding PreviewEnable, Mode=TwoWay}"/>
      <StackPanel Orientation="Horizontal" Spacing="30">
        <Grid x:Name="ActionGrid" ToolTip.Tip="Click edge to select probing action."
              Width="160" Height="160" Margin="5,10,0,0"
              RowDefinitions="80,80" ColumnDefinitions="80,80">
          <RadioButton Theme="{StaticResource RotFlagRadioTheme}" GroupName="rotEdge"
                       IsChecked="{Binding ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=AD}">
            <Image Width="76" Height="76" Source="avares://CNC.Controls.Probing.Avalonia/Views/Resources/RotaterAD.png"/>
          </RadioButton>
          <RadioButton Grid.Column="1" Theme="{StaticResource RotFlagRadioTheme}" GroupName="rotEdge"
                       IsChecked="{Binding ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=CD}">
            <Image Width="76" Height="76" Source="avares://CNC.Controls.Probing.Avalonia/Views/Resources/RotaterCD.png"/>
          </RadioButton>
          <RadioButton Grid.Row="1" Theme="{StaticResource RotFlagRadioTheme}" GroupName="rotEdge"
                       IsChecked="{Binding ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=AB}">
            <Image Width="76" Height="76" Source="avares://CNC.Controls.Probing.Avalonia/Views/Resources/RotaterAB.png"/>
          </RadioButton>
          <RadioButton Grid.Row="1" Grid.Column="1" Theme="{StaticResource RotFlagRadioTheme}" GroupName="rotEdge"
                       IsChecked="{Binding ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=CB}">
            <Image Width="76" Height="76" Source="avares://CNC.Controls.Probing.Avalonia/Views/Resources/RotaterCB.png"/>
          </RadioButton>
        </Grid>
        <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" Padding="6" CornerRadius="2"
                IsVisible="{Binding PreviewEnable, Converter={StaticResource ToVisibleConverter}}" VerticalAlignment="Top">
          <StackPanel Spacing="4">
            <TextBlock Text="Preview" FontWeight="SemiBold"/>
            <TextBox IsReadOnly="True" Text="{Binding PreviewText, Mode=OneWay}" TextWrapping="NoWrap"
                     Width="245" Height="150" FontSize="10" FontFamily="Verdana"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </StackPanel>
    <StackPanel Margin="5,0,0,5" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Spacing="4">
      <Button Content="Start" Width="75"
              IsEnabled="{Binding Grbl.IsJobRunning, Converter={StaticResource IsNotRunningConverter}}"
              Click="OnStartClick"/>
      <Button Content="Stop" Width="75"
              IsEnabled="{Binding Grbl.IsJobRunning}"
              Click="OnStopClick"/>
      <Button Content="Apply" Width="75"
              IsEnabled="{Binding CanApplyTransform}"
              Click="OnApplyClick"/>
    </StackPanel>
  </Grid>
</UserControl>
