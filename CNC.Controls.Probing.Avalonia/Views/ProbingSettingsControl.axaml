<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CNC.Controls.Probing.ProbingSettingsControl"
             Width="310">
  <GroupBox Header="Probing" BorderBrush="{DynamicResource ThemeBorderLowBrush}">
    <WrapPanel Orientation="Vertical" ItemWidth="290">
      <CheckBox Content="Manually validate probe is connected" FontSize="12"
                IsChecked="{Binding Probing.ValidateProbeConnected, Mode=TwoWay}"
                ToolTip.Tip="A dialog will be shown until the probe is asserted or cancelled."/>
      <CheckBox Content="Check probe status before start (G59.3)" FontSize="12"
                IsChecked="{Binding Probing.CheckProbeStatus, Mode=TwoWay}"
                ToolTip.Tip="Controller alarm if probe is asserted when disabled."/>
    </WrapPanel>
  </GroupBox>
</UserControl>
