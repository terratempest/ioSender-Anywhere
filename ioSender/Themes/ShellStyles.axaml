<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:workspaceControls="using:ioSender.Workspace.Controls">

  <Styles.Resources>
    <SolidColorBrush x:Key="IoSenderWarningBrush" Color="#EF5350"/>
    <SolidColorBrush x:Key="IoSenderConnectedBrush" Color="#66BB6A"/>
    <SolidColorBrush x:Key="IoSenderDisconnectedBrush" Color="#FFB74D"/>
  </Styles.Resources>

  <Style Selector="Border.panel-chrome">
    <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderLowBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="4"/>
    <Setter Property="CornerRadius" Value="2"/>
  </Style>

  <Style Selector="TextBlock.warning-text">
    <Setter Property="Foreground" Value="{StaticResource IoSenderWarningBrush}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style Selector="Border.workspace-region-edit">
    <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
  </Style>

  <Style Selector="Border.app-titlebar">
    <Setter Property="Background" Value="{DynamicResource ThemeControlLowBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderLowBrush}"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
  </Style>

  <Style Selector="Border.quickaccess-sidebar">
    <Setter Property="Background" Value="{DynamicResource ThemeControlMidBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderLowBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="2"/>
  </Style>

  <Style Selector="Button.quickaccess-tab">
    <Setter Property="Width" Value="30"/>
    <Setter Property="Height" Value="65"/>
    <Setter Property="Padding" Value="-8"/>
    <Setter Property="Margin" Value="0"/>
    <Setter Property="ClipToBounds" Value="True"/>
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Background" Value="{DynamicResource ThemeControlLowBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderLowBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="3"/>
  </Style>

  <Style Selector="Button.quickaccess-add">
    <Setter Property="Width" Value="30"/>
    <Setter Property="Height" Value="30"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Margin" Value="0,2,0,0"/>
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style Selector="Border.layout-lock-indicator">
    <Setter Property="Width" Value="18"/>
    <Setter Property="Height" Value="18"/>
    <Setter Property="CornerRadius" Value="9"/>
    <Setter Property="Margin" Value="0,0,3,0"/>
    <Setter Property="Background" Value="{DynamicResource ThemeControlHighBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <Style Selector="TextBlock.layout-lock-indicator-text">
    <Setter Property="HorizontalAlignment" Value="Center"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
  </Style>

  <Style Selector="Border.workspace-split-preview">
    <Setter Property="Background" Value="{DynamicResource ThemeAccentBrushHigh}"/>
    <Setter Property="Opacity" Value="0.85"/>
  </Style>

  <Style Selector="Border.workspace-drop-target">
    <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrushHigh}"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>

  <Style Selector="Border.workspace-splitter-line">
    <Setter Property="Background" Value="{DynamicResource ThemeBorderLowBrush}"/>
  </Style>

  <Style Selector="GridSplitter.workspace-splitter">
    <Setter Property="Background" Value="{DynamicResource ThemeBorderLowBrush}"/>
  </Style>

  <Style Selector="GridSplitter.workspace-splitter:pointerover">
    <Setter Property="Background" Value="{DynamicResource ThemeBorderMidBrush}"/>
  </Style>

  <Style Selector="workspaceControls|WorkspaceGridSplitter.workspace-splitter">
    <Setter Property="Background" Value="{DynamicResource ThemeBorderLowBrush}"/>
  </Style>

  <Style Selector="workspaceControls|WorkspaceGridSplitter.workspace-splitter:pointerover">
    <Setter Property="Background" Value="{DynamicResource ThemeBorderMidBrush}"/>
  </Style>

</Styles>
