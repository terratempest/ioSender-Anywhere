<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ioSender.ViewModels"
        xmlns:views="using:ioSender.Views"
        xmlns:cnc="using:CNC.Controls.Avalonia.Views"
        xmlns:probing="using:CNC.Controls.Probing"
        xmlns:config="using:CNC.Controls.Config"
        xmlns:qa="using:ioSender.QuickAccess"
        xmlns:chrome="using:Avalonia.Controls.Chrome"
        xmlns:local="using:ioSender"
        xmlns:loc="using:CNC.Localization.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1020" d:DesignHeight="685"
        x:Class="ioSender.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ioSender"
        Icon="/Assets/iosendericon.ico"
        MinWidth="800" MinHeight="600"
        Width="1020" Height="685"
        Background="{DynamicResource ThemeBackgroundBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="34">

  <Window.WindowDecorationsTheme>
    <ControlTheme TargetType="chrome:WindowDrawnDecorations">
      <Setter Property="DefaultTitleBarHeight" Value="34"/>
      <Setter Property="DefaultFrameThickness" Value="0"/>
      <Setter Property="DefaultShadowThickness" Value="0"/>
      <Setter Property="Template">
        <local:EmptyWindowDrawnDecorationsTemplate/>
      </Setter>
    </ControlTheme>
  </Window.WindowDecorationsTheme>

  <DockPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
    <Border x:Name="TitleBar"
            DockPanel.Dock="Top"
            Height="34"
            Padding="10,0,4,0"
            Background="{DynamicResource ThemeControlLowBrush}"
            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
            BorderThickness="0,0,0,1"
            chrome:WindowDecorationProperties.ElementRole="TitleBar">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center">
          <Image Source="/Assets/iosendericon.ico" Width="16" Height="16"/>
          <TextBlock Text="ioSender"
                     VerticalAlignment="Center"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource ThemeForegroundBrush}"/>
        </StackPanel>

        <Menu Grid.Column="1"
              Background="Transparent"
              VerticalAlignment="Center"
              chrome:WindowDecorationProperties.ElementRole="User">
        <MenuItem x:Name="MnuFile" Header="_File" loc:Localize.Key="ioSender.mainwindow.mnu_file">
          <MenuItem x:Name="MnuFileOpen" Header="_Open G-code..." Click="OnOpenGCodeClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_open"/>
          <MenuItem x:Name="MnuFileSave" Header="_Save" IsEnabled="False" Click="OnSaveProgramClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_save" loc:Localize.Fallback="_Save"/>
          <MenuItem x:Name="MnuTransform" Header="_Transform" IsEnabled="False"
                    loc:Localize.Key="ioSender.mainwindow.mnu_transform" loc:Localize.Fallback="_Transform">
            <MenuItem x:Name="MnuDragKnife" Header="Add drag knife moves" Click="OnDragKnifeTransformClick"
                      loc:Localize.Key="ioSender.mainwindow.str_mnuDragKnife" loc:Localize.Fallback="Add drag knife moves"/>
          </MenuItem>
          <Separator/>
          <MenuItem x:Name="MnuFileConnect" Header="_Connect..." Click="OnConnectClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_connect" loc:Localize.Fallback="_Connect..."/>
          <MenuItem x:Name="MnuFileExit" Header="_Exit" Click="OnExitClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_exit"/>
        </MenuItem>

        <MenuItem x:Name="MnuView" Header="_View"
                  loc:Localize.Key="ioSender.mainwindow.mnu_view" loc:Localize.Fallback="_View">
          <MenuItem x:Name="MnuLockLayout" Header="_Lock layout" ToggleType="CheckBox" IsChecked="True"
                    Click="OnLockLayoutClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_lockLayout" loc:Localize.Fallback="_Lock layout"/>
          <MenuItem x:Name="MnuResetLayout" Header="_Reset layout" Click="OnResetLayoutClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_resetLayout" loc:Localize.Fallback="_Reset layout"/>
          <MenuItem x:Name="MnuLayouts" Header="_Layouts"
                    loc:Localize.Key="ioSender.mainwindow.mnu_layouts" loc:Localize.Fallback="_Layouts">
            <MenuItem x:Name="MnuPresetClassic" Header="_Classic" Click="OnPresetClassicClick"
                      loc:Localize.Key="ioSender.mainwindow.mnu_presetClassic" loc:Localize.Fallback="_Classic"/>
            <MenuItem x:Name="MnuPresetTouch" Header="_Touch" Click="OnPresetTouchClick"
                      loc:Localize.Key="ioSender.mainwindow.mnu_presetTouch" loc:Localize.Fallback="_Touch"/>
            <MenuItem x:Name="MnuPresetXL" Header="_XL" Click="OnPresetXLClick"
                      loc:Localize.Key="ioSender.mainwindow.mnu_presetXL" loc:Localize.Fallback="_XL"/>
          </MenuItem>
          <MenuItem x:Name="MnuSaveLayout" Header="_Save layout..." Click="OnSaveLayoutClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_saveLayout" loc:Localize.Fallback="_Save layout..."/>
          <MenuItem x:Name="MnuDeleteLayout" Header="_Delete layout..." Click="OnDeleteLayoutClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_deleteLayout" loc:Localize.Fallback="_Delete layout..."/>
          <MenuItem x:Name="MnuSidebar" Header="_Sidebar"
                    loc:Localize.Key="ioSender.mainwindow.mnu_sidebar" loc:Localize.Fallback="_Sidebar">
            <MenuItem x:Name="MnuSidebarLeft" Header="_Left side" ToggleType="CheckBox"
                      Click="OnSidebarLeftMenuClick"
                      loc:Localize.Key="ioSender.mainwindow.mnu_sidebarLeft" loc:Localize.Fallback="_Left side"/>
            <MenuItem x:Name="MnuSidebarRight" Header="_Right side" ToggleType="CheckBox"
                      Click="OnSidebarRightMenuClick"
                      loc:Localize.Key="ioSender.mainwindow.mnu_sidebarRight" loc:Localize.Fallback="_Right side"/>
          </MenuItem>
          <Separator/>
          <MenuItem x:Name="MnuViewSdCard" Header="_SD Card..." Click="OnSdCardClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_sdCard" loc:Localize.Fallback="_SD Card..."/>
          <MenuItem x:Name="MnuViewLatheWizards" Header="_Lathe Wizards..." Click="OnLatheWizardsClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_latheWizards" loc:Localize.Fallback="_Lathe Wizards..."/>
          <Separator/>
          <MenuItem x:Name="MnuViewCamera" Header="_Camera..." Click="OnCameraClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_camera"/>
          <MenuItem x:Name="MnuRefreshPorts" Header="_Refresh serial ports" Click="OnRefreshPortsClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_refreshPorts" loc:Localize.Fallback="_Refresh serial ports"/>
        </MenuItem>

        <MenuItem x:Name="MnuSettings" Header="_Settings"
                  loc:Localize.Key="ioSender.mainwindow.mnu_settings" loc:Localize.Fallback="_Settings">
          <MenuItem x:Name="MnuGrblSettings" Header="Settings: _Grbl" Click="OnGrblSettingsClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_grblSettings" loc:Localize.Fallback="Settings: _Grbl"/>
          <MenuItem x:Name="MnuAppSettings" Header="Settings: _App" Click="OnAppSettingsClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_appSettings" loc:Localize.Fallback="Settings: _App"/>
          <MenuItem x:Name="MnuCheckMode" Header="Check _mode"
                    ToggleType="CheckBox"
                    Click="OnCheckModeMenuClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_checkMode" loc:Localize.Fallback="Check mode"/>
        </MenuItem>

        <MenuItem x:Name="MnuHelp" Header="_Help"
                  loc:Localize.Key="ioSender.mainwindow.mnu_help" loc:Localize.Fallback="_Help">
          <MenuItem x:Name="MnuHelpWiki" Header="_Wiki" Click="OnHelpWikiClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_wiki" loc:Localize.Fallback="_Wiki"/>
          <MenuItem x:Name="MnuHelpUsageTips" Header="Usage _tips" Click="OnHelpUsageTipsClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_usageTips" loc:Localize.Fallback="Usage _tips"/>
          <MenuItem x:Name="MnuHelpBriefTour" Header="A _brief tour" Click="OnHelpBriefTourClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_briefTour" loc:Localize.Fallback="A _brief tour"/>
          <MenuItem x:Name="MnuHelpVideoTutorials" Header="_Video tutorials" Click="OnHelpVideoTutorialsClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_videoTutorials" loc:Localize.Fallback="_Video tutorials"/>
          <MenuItem x:Name="MnuHelpErrorsAndAlarms" Header="_Error and alarm codes" Click="OnHelpErrorsAndAlarmsClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_errorsAndAlarms" loc:Localize.Fallback="_Error and alarm codes"/>
          <MenuItem x:Name="MnuHelpAbout" Header="_About" Click="OnHelpAboutClick"
                    loc:Localize.Key="ioSender.mainwindow.mnu_about" loc:Localize.Fallback="_About"/>
        </MenuItem>
        </Menu>

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    Spacing="6"
                    DataContext="{Binding Grbl}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="24,0,8,0"
                    chrome:WindowDecorationProperties.ElementRole="User">
          <cnc:StatusPillControl Label="TLO"
                                 IsSet="{Binding IsToolOffsetActive, Mode=OneWay}"
                                 IsVisible="{Binding IsToolOffsetIndicatorVisible}"/>
          <cnc:StatusPillControl Label="TLO ref'd"
                                 IsSet="{Binding IsTloReferenceSet, Mode=OneWay}"/>
        </StackPanel>

        <cnc:SignalsControl Grid.Column="4"
                            DataContext="{Binding Grbl}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0"
                            chrome:WindowDecorationProperties.ElementRole="User"/>

        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="2">
          <Button x:Name="BtnWindowMinimize"
                  Width="36" Height="30" Padding="10"
                  ToolTip.Tip="Minimize"
                  Click="OnWindowMinimizeClick"
                  chrome:WindowDecorationProperties.ElementRole="MinimizeButton">
            <Viewbox Width="12" Height="12">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource ThemeForegroundBrush}"
                      Data="M5,12 L19,12 L19,14 L5,14 Z"/>
              </Canvas>
            </Viewbox>
          </Button>
          <Button x:Name="BtnWindowMaximize"
                  Width="36" Height="30" Padding="9"
                  ToolTip.Tip="Maximize"
                  Click="OnWindowMaximizeClick"
                  chrome:WindowDecorationProperties.ElementRole="MaximizeButton">
            <Viewbox Width="12" Height="12">
              <Canvas Width="24" Height="24">
                <Path x:Name="IconWindowMaximize"
                      Fill="{DynamicResource ThemeForegroundBrush}"
                      Data="M5,5 L19,5 L19,19 L5,19 Z M7,7 L7,17 L17,17 L17,7 Z"/>
              </Canvas>
            </Viewbox>
          </Button>
          <Button x:Name="BtnWindowFullscreen"
                  Width="36" Height="30" Padding="8"
                  ToolTip.Tip="Fullscreen"
                  Click="OnWindowFullscreenClick"
                  chrome:WindowDecorationProperties.ElementRole="User">
            <Viewbox Width="13" Height="13">
              <Canvas Width="24" Height="24">
                <Path x:Name="IconWindowFullscreen"
                      Fill="{DynamicResource ThemeForegroundBrush}"
                      Data="M4,4 L10,4 L10,6 L7,6 L7,9 L5,9 L5,5 L4,5 Z M14,4 L20,4 L20,10 L18,10 L18,7 L15,7 L15,5 L19,5 L19,4 Z M5,14 L7,14 L7,17 L10,17 L10,19 L4,19 L4,18 L5,18 Z M18,14 L20,14 L20,20 L14,20 L14,18 L17,18 L17,15 L18,15 Z"/>
              </Canvas>
            </Viewbox>
          </Button>
          <Button x:Name="BtnWindowClose"
                  Width="36" Height="30" Padding="9"
                  ToolTip.Tip="Close"
                  Click="OnWindowCloseClick"
                  chrome:WindowDecorationProperties.ElementRole="CloseButton">
            <Viewbox Width="12" Height="12">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource ThemeForegroundBrush}"
                      Data="M5.6,4.2 L12,10.6 L18.4,4.2 L19.8,5.6 L13.4,12 L19.8,18.4 L18.4,19.8 L12,13.4 L5.6,19.8 L4.2,18.4 L10.6,12 L4.2,5.6 Z"/>
              </Canvas>
            </Viewbox>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border DockPanel.Dock="Bottom" Padding="6,4"
            Background="{DynamicResource ThemeControlLowBrush}"
            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
            BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="Auto,8,*,8,Auto,8,Auto">
        <TextBlock Grid.Column="0" Text="{Binding Grbl.Blocks, StringFormat='Blocks: {0}'}"/>
        <TextBlock Grid.Column="2" Text="{Binding Grbl.Message}" TextWrapping="NoWrap"/>
        <TextBlock Grid.Column="4" Text="{Binding Grbl.RunTime, StringFormat='Run time: {0}'}"/>
        <TextBlock Grid.Column="6">
          <TextBlock.Text>
            <MultiBinding StringFormat="Jog | Step: {0}  Feed: {1:####0}">
              <Binding Path="Grbl.JogStep"/>
              <Binding Path="Jog.FeedRate"/>
            </MultiBinding>
          </TextBlock.Text>
        </TextBlock>
      </Grid>
    </Border>

    <Grid RowDefinitions="Auto,*">
      <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
            Background="{DynamicResource ThemeControlLowBrush}">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" Margin="4,3,6,3"
                    VerticalAlignment="Center">
          <Button x:Name="BtnOpenProgram" Width="30" Height="28" Padding="5"
                  ToolTip.Tip="Open program" Click="OnOpenGCodeClick">
            <Viewbox Width="16" Height="16">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource ThemeForegroundBrush}"
                      Data="M3,6 L9,6 L11,8 L21,8 L21,19 L3,19 Z M5,10 L5,17 L19,17 L19,10 Z"/>
              </Canvas>
            </Viewbox>
          </Button>
          <Button x:Name="BtnReloadProgram" Width="30" Height="28" Padding="5"
                  ToolTip.Tip="Reload current program" Click="OnReloadProgramClick">
            <Viewbox Width="16" Height="16">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource ThemeForegroundBrush}"
                      Data="M12,4 C8.8,4 6.1,5.8 4.7,8.4 L7,8.4 L7,10.4 L1.8,10.4 L1.8,5.2 L3.8,5.2 L3.8,6.8 C5.6,3.9 8.6,2 12,2 C16.8,2 20.8,5.4 21.8,9.9 L19.8,9.9 C18.9,6.5 15.8,4 12,4 Z M22.2,13.6 L22.2,18.8 L20.2,18.8 L20.2,17.2 C18.4,20.1 15.4,22 12,22 C7.2,22 3.2,18.6 2.2,14.1 L4.2,14.1 C5.1,17.5 8.2,20 12,20 C15.2,20 17.9,18.2 19.3,15.6 L17,15.6 L17,13.6 Z"/>
              </Canvas>
            </Viewbox>
          </Button>
          <Button x:Name="BtnCloseProgram" Width="30" Height="28" Padding="6"
                  ToolTip.Tip="Close current program" Click="OnCloseProgramClick">
            <Viewbox Width="14" Height="14">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource ThemeForegroundBrush}"
                      Data="M5.6,4.2 L12,10.6 L18.4,4.2 L19.8,5.6 L13.4,12 L19.8,18.4 L18.4,19.8 L12,13.4 L5.6,19.8 L4.2,18.4 L10.6,12 L4.2,5.6 Z"/>
              </Canvas>
            </Viewbox>
          </Button>
          <Button x:Name="BtnServerStatus" Width="30" Height="28" Padding="6"
                  Classes="status-indicator"
                  ToolTip.Tip="Connect" Click="OnServerStatusClick">
            <Viewbox Width="14" Height="14">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource ThemeForegroundBrush}"
                      Data="M12,3 C16.9,3 21,7.1 21,12 C21,16.9 16.9,21 12,21 C7.1,21 3,16.9 3,12 C3,7.1 7.1,3 12,3 Z M12,5 C8.2,5 5,8.2 5,12 C5,15.8 8.2,19 12,19 C15.8,19 19,15.8 19,12 C19,8.2 15.8,5 12,5 Z M11,7 L13,7 L13,13 L11,13 Z M11,15 L13,15 L13,17 L11,17 Z"/>
              </Canvas>
            </Viewbox>
          </Button>
        </StackPanel>

        <TabControl x:Name="ShellTabs" Grid.Column="1" Background="Transparent"
                    SelectionChanged="OnShellTabsSelectionChanged">
          <TabItem x:Name="TabHome" Header="Home"
                   loc:Localize.Key="ioSender.mainwindow.tab_home" loc:Localize.Fallback="Home">
            <Grid/>
          </TabItem>
          <TabItem x:Name="TabProbing" Header="Probing"
                   loc:Localize.Key="ioSender.mainwindow.tab_probing" loc:Localize.Fallback="Probing">
            <Grid/>
          </TabItem>
          <TabItem x:Name="TabOffsets" Header="Offsets"
                   loc:Localize.Key="ioSender.mainwindow.tab_offsets" loc:Localize.Fallback="Offsets">
            <Grid/>
          </TabItem>
          <TabItem x:Name="TabSettings" IsVisible="False">
            <Grid/>
          </TabItem>
        </TabControl>

        <cnc:StatusControl Grid.Column="2"
                           DataContext="{Binding Grbl}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="4,3,6,3"/>
      </Grid>

      <Grid Grid.Row="1" ClipToBounds="False">
        <DockPanel x:Name="ClientAreaDock" LastChildFill="True" ClipToBounds="False">
          <qa:QuickAccessSidebarHost x:Name="LeftQuickAccess"
                                     DockPanel.Dock="Left"
                                     ZIndex="300"
                                     Width="40"
                                     IsVisible="False"/>
          <qa:QuickAccessSidebarHost x:Name="RightQuickAccess"
                                     DockPanel.Dock="Right"
                                     ZIndex="300"
                                     Width="40"
                                     IsVisible="False"/>
          <Grid x:Name="ClientAreaGrid" ClipToBounds="False">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
              <views:JobView x:Name="JobViewControl"
                             DataContext="{Binding Grbl}"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"/>
              <ContentControl x:Name="ProbingPageHost"
                              IsVisible="False"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>
              <ContentControl x:Name="OffsetsPageHost"
                              IsVisible="False"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>
              <ContentControl x:Name="GrblConfigPageHost"
                              IsVisible="False"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>
              <ContentControl x:Name="AppConfigPageHost"
                              IsVisible="False"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>
            </Grid>
            <Border x:Name="QuickAccessBackdrop"
                    ZIndex="100"
                    Background="#66000000"
                    IsVisible="False"
                    IsHitTestVisible="False"
                    PointerPressed="OnQuickAccessBackdropPressed"/>
          </Grid>
        </DockPanel>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
