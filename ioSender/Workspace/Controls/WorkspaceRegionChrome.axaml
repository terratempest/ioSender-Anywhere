<Border xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ioSender.Workspace.Controls.WorkspaceRegionChrome"
        Classes="panel-chrome workspace-region"
        BorderThickness="1"
        Padding="0"
        MinWidth="80"
        MinHeight="60">
  <DockPanel>
    <Border x:Name="TitleBar" DockPanel.Dock="Top" Padding="6,4"
            Background="{DynamicResource ThemeControlMidBrush}"
            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
            BorderThickness="0,0,0,1"
            Cursor="Hand">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <TextBlock x:Name="TitleText" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBlock x:Name="HeaderStatusText" Grid.Column="1" VerticalAlignment="Center"
                   Margin="8,0,0,0" FontWeight="SemiBold" IsVisible="False"/>
        <StackPanel x:Name="LockIndicators" Grid.Column="2" Orientation="Horizontal"
                    VerticalAlignment="Center" IsVisible="False" Margin="6,0,0,0">
          <Border x:Name="WidthLockIndicator" Classes="layout-lock-indicator"
                  ToolTip.Tip="Layout width locked" IsVisible="False">
            <TextBlock Classes="layout-lock-indicator-text" Text="W"/>
          </Border>
          <Border x:Name="HeightLockIndicator" Classes="layout-lock-indicator"
                  ToolTip.Tip="Layout height locked" IsVisible="False">
            <TextBlock Classes="layout-lock-indicator-text" Text="H"/>
          </Border>
        </StackPanel>
        <TextBlock x:Name="EditHint" Grid.Column="3" Text="⋮⋮" Opacity="0.5" VerticalAlignment="Center"
                   IsVisible="False" Margin="4,0,0,0"/>
      </Grid>
    </Border>
    <ScrollViewer x:Name="EditorScroll"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
      <ContentPresenter x:Name="EditorHost" Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>
    </ScrollViewer>
  </DockPanel>
</Border>
