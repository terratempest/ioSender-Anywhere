<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="using:Avalonia.Controls.Primitives"
        xmlns:controls="using:CNC.Controls.Avalonia.Controls">

  <StyleInclude Source="avares://CNC.Controls.Avalonia/Themes/ButtonStyles.axaml"/>
  <StyleInclude Source="avares://CNC.Controls.Avalonia/Views/DropdownSelect.axaml"/>

  <Style Selector="Border.disconnected-overlay">
    <Setter Property="Background" Value="{DynamicResource IoSenderOverlayBrush}"/>
    <Setter Property="IsHitTestVisible" Value="True"/>
  </Style>

  <Style Selector="TextBlock.overlay-message">
    <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
  </Style>

  <Style Selector="DataGrid.gcode-program-grid">
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="VerticalAlignment" Value="Stretch"/>
    <Setter Property="GridLinesVisibility" Value="Horizontal"/>
    <Setter Property="HeadersVisibility" Value="Column"/>
  </Style>

  <Style Selector="DataGridRow.gcode-current">
    <Setter Property="Background" Value="{DynamicResource IoSenderJogSelectedBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
  </Style>
  
  <Style Selector="DataGridRow.gcode-done">
    <Setter Property="Opacity" Value="0.65"/>
  </Style>

</Styles>
