<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:CNC.Controls.Avalonia.Views"
             x:Class="CNC.Controls.Avalonia.Views.GotoControl"
             Focusable="False"
             Width="250" Height="122">
  <Border Classes="panel-chrome" BorderThickness="1" Padding="4" Width="250">
    <StackPanel>
      <TextBlock Text="Goto" FontWeight="Bold" Margin="0,0,0,4"/>
      <views:GotoBaseControl Margin="36,0,0,0"/>
    </StackPanel>
  </Border>
</UserControl>
