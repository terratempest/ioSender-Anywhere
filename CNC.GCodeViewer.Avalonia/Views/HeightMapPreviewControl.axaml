<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:CNC.GCodeViewer.Avalonia.Views"
             x:Class="CNC.GCodeViewer.Avalonia.Views.HeightMapPreviewControl">
  <Grid>
    <views:ToolpathGlControl x:Name="GlViewport"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"/>
    <Panel x:Name="ViewportInput"
           Background="Transparent"
           HorizontalAlignment="Stretch"
           VerticalAlignment="Stretch"
           Cursor="Hand"/>
  </Grid>
</UserControl>
