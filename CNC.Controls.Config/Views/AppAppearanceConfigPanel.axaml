<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CNC.Controls.Config.AppAppearanceConfigPanel"
             Width="310">
  <GroupBox Header="Appearance" BorderBrush="{DynamicResource ThemeBorderLowBrush}">
    <WrapPanel Orientation="Vertical" ItemWidth="290">
      <Grid ColumnDefinitions="90,*" Margin="0,0,0,4">
        <TextBlock Grid.Column="0" Text="Theme:" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <ComboBox x:Name="ThemeCombo" Grid.Column="1" Margin="4,0,0,0" Width="120"
                  FontSize="12" HorizontalAlignment="Left"
                  SelectionChanged="OnThemeSelectionChanged"/>
      </Grid>

      <Grid ColumnDefinitions="90,*" Margin="0,0,0,4">
        <TextBlock Grid.Column="0" Text="Locale:" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <TextBox Grid.Column="1" Margin="4,0,0,0" Width="120" FontSize="12" HorizontalAlignment="Left"
                 Text="{Binding Locale, Mode=TwoWay}"
                 PlaceholderText="empty = default"
                 ToolTip.Tip="UI culture (e.g. de-DE). Restart may be required."/>
      </Grid>

      <TextBlock Text="Theme applies immediately."
                 FontSize="11" Opacity="0.75" TextWrapping="Wrap" Margin="0,4,0,0"/>
    </WrapPanel>
  </GroupBox>
</UserControl>
