<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:CNC.Controls.Config"
             x:Class="CNC.Controls.Config.AppAppearanceConfigPanel"
             MinWidth="720">
  <GroupBox Header="Appearance" TextElement.FontSize="12"
    BorderBrush="{DynamicResource ThemeBorderLowBrush}">
    <Grid ColumnDefinitions="2*,Auto,2*,Auto,3*" RowDefinitions="Auto,*" ColumnSpacing="10">
      <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
        <Grid ColumnDefinitions="90,*">
          <TextBlock Grid.Column="0" Text="Theme:" HorizontalAlignment="Right" VerticalAlignment="Center"/>
          <ComboBox x:Name="ThemeCombo" Grid.Column="1" Margin="4,0,0,0" Width="170"
                  HorizontalAlignment="Left"
                  SelectionChanged="OnThemeSelectionChanged"/>
        </Grid>
        <Button Content="Reset colors" MinWidth="95" Click="OnResetColorsClick"/>
        <Button Content="Save as theme" MinWidth="105" Click="OnSaveAsThemeClick"/>
        <CheckBox x:Name="UseSystemAccentCheck"
                  Content="Use system accent color"
                  VerticalAlignment="Center"/>
      </StackPanel>

      <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Text="Theme colors" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <StackPanel x:Name="MainColorsPanel" Spacing="4"/>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Row="1" Grid.Column="1" Width="1" Background="{DynamicResource ThemeBorderLowBrush}"/>

      <ScrollViewer Grid.Row="1" Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Text="3D viewer colors" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <StackPanel x:Name="ViewerColorsPanel" Spacing="4"/>
          <Button x:Name="PreviewViewerButton" Content="Preview 3D viewer" Margin="0,8,0,0"
                  Click="OnPreviewViewerClick"/>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Row="1" Grid.Column="3" Width="1" Background="{DynamicResource ThemeBorderLowBrush}"/>

      <Border Grid.Row="1" Grid.Column="4" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1"
              MinWidth="260" MinHeight="220">
        <local:ThemeViewerPreviewControl x:Name="ViewerPreview"/>
      </Border>
    </Grid>
  </GroupBox>
</UserControl>
