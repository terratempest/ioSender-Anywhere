<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cnc="using:CNC.Controls.Avalonia.Views"
             x:Class="CNC.Controls.Config.JogUiConfigControl"
             Classes="settings-panel">
  <GroupBox Header="UI jogging" Classes="form-section">
    <WrapPanel Classes="settings-form">
      <cnc:NumericField Classes="form-field" Label="Distance 3:" Unit="mm" Format="###0.0##"
                        Value="{Binding JogUiMetric.Distance3, Mode=TwoWay}"/>
      <cnc:NumericField Classes="form-field" Label="Distance 2:" Unit="mm" Format="###0.0##"
                        Value="{Binding JogUiMetric.Distance2, Mode=TwoWay}"/>
      <cnc:NumericField Classes="form-field" Label="Distance 1:" Unit="mm" Format="###0.0##"
                        Value="{Binding JogUiMetric.Distance1, Mode=TwoWay}"/>
      <cnc:NumericField Classes="form-field" Label="Distance 0:" Unit="mm" Format="###0.0##"
                        Value="{Binding JogUiMetric.Distance0, Mode=TwoWay}"/>
      <cnc:NumericField Classes="form-field" Label="Feedrate 3:" Unit="mm/min" Format="####0"
                        Value="{Binding JogUiMetric.Feedrate3, Mode=TwoWay}"/>
      <cnc:NumericField Classes="form-field" Label="Feedrate 2:" Unit="mm/min" Format="####0"
                        Value="{Binding JogUiMetric.Feedrate2, Mode=TwoWay}"/>
      <cnc:NumericField Classes="form-field" Label="Feedrate 1:" Unit="mm/min" Format="####0"
                        Value="{Binding JogUiMetric.Feedrate1, Mode=TwoWay}"/>
      <cnc:NumericField Classes="form-field" Label="Feedrate 0:" Unit="mm/min" Format="####0"
                        Value="{Binding JogUiMetric.Feedrate0, Mode=TwoWay}"/>
    </WrapPanel>
  </GroupBox>
</UserControl>
