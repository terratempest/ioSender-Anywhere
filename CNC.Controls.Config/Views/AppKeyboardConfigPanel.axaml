<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="using:CNC.App"
             x:Class="CNC.Controls.Config.AppKeyboardConfigPanel"
             Classes="settings-panel">
  <GroupBox Header="Keyboard mappings" Classes="form-section">
    <WrapPanel Classes="settings-form">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <TextBlock Classes="ui-label" Text="Popup keyboard:" VerticalAlignment="Center"/>
        <Border Width="12" Height="12"
                CornerRadius="6"
                Background="{DynamicResource ThemeControlMidBrush}"
                BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                BorderThickness="1"
                ToolTip.Tip="Controls whether clicking editable input fields opens the on-screen keyboard, and how many clicks are required."
                VerticalAlignment="Center">
          <TextBlock Text="i"
                     FontSize="8"
                     FontWeight="Bold"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
      </StackPanel>

      <ComboBox Classes="dropdown-select" x:Name="PopupKeyboardTriggerCombo" HorizontalAlignment="Stretch"
                SelectionChanged="OnPopupKeyboardTriggerChanged"
                Margin="0,0,0,8"/>

      <TextBlock Classes="ui-label" Text="Jog mode:"/>

      <ComboBox Classes="dropdown-select" x:Name="JogModeCombo" HorizontalAlignment="Stretch"
                SelectionChanged="OnJogModeChanged"/>

      <TextBlock x:Name="KeyMapPathText" Classes="help-text" Margin="0,4,0,0"/>

      <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
        <Button x:Name="SaveKeyMapBtn" Classes="form-action" Content="Save mappings" MinWidth="110" Click="OnSaveKeyMapClick"/>
        <Button x:Name="LoadKeyMapBtn" Classes="form-action" Content="Load mappings" MinWidth="110" Click="OnLoadKeyMapClick"/>
      </StackPanel>

      <TextBlock x:Name="KeyMapStatusText" Classes="help-text" Margin="0,4,0,0"/>
    </WrapPanel>
  </GroupBox>
</UserControl>
