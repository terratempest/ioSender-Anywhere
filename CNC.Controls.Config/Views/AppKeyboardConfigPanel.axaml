<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="using:CNC.App"
             x:Class="CNC.Controls.Config.AppKeyboardConfigPanel"
             Width="310">
  <GroupBox Header="Keyboard mappings" BorderBrush="{DynamicResource ThemeBorderLowBrush}">
    <WrapPanel Orientation="Vertical" ItemWidth="290">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <TextBlock Text="Popup keyboard:" FontSize="12" VerticalAlignment="Center"/>
        <Border Width="12" Height="12"
                CornerRadius="6"
                Background="{DynamicResource ThemeControlMidBrush}"
                BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                BorderThickness="1"
                ToolTip.Tip="Controls whether clicking editable input fields opens the on-screen keyboard, and how many clicks are required."
                VerticalAlignment="Center">
          <TextBlock Text="i"
                     FontSize="8"
                     FontWeight="Bold"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
      </StackPanel>

      <ComboBox x:Name="PopupKeyboardTriggerCombo" FontSize="12" HorizontalAlignment="Stretch"
                SelectionChanged="OnPopupKeyboardTriggerChanged"
                Margin="0,0,0,8"/>

      <TextBlock Text="Jog mode:" FontSize="12"/>

      <ComboBox x:Name="JogModeCombo" FontSize="12" HorizontalAlignment="Stretch"
                SelectionChanged="OnJogModeChanged"/>

      <TextBlock x:Name="KeyMapPathText" TextWrapping="Wrap" FontSize="11" Opacity="0.85" Margin="0,4,0,0"/>

      <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
        <Button x:Name="SaveKeyMapBtn" Content="Save mappings" MinWidth="110" FontSize="12"
                HorizontalContentAlignment="Center" Click="OnSaveKeyMapClick"/>
        <Button x:Name="LoadKeyMapBtn" Content="Load mappings" MinWidth="110" FontSize="12"
                HorizontalContentAlignment="Center" Click="OnLoadKeyMapClick"/>
      </StackPanel>

      <TextBlock x:Name="KeyMapStatusText" TextWrapping="Wrap" FontSize="11" Opacity="0.85" Margin="0,4,0,0"/>
    </WrapPanel>
  </GroupBox>
</UserControl>
