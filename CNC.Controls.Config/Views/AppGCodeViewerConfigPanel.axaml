<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cnc="using:CNC.Controls.Avalonia.Views"
             x:Class="CNC.Controls.Config.AppGCodeViewerConfigPanel"
             Width="310">
  <GroupBox Header="G-code viewer" BorderBrush="{DynamicResource ThemeBorderLowBrush}">
    <WrapPanel Orientation="Vertical" ItemWidth="290">
      <CheckBox Content="Enable" FontSize="12" IsChecked="{Binding GCodeViewer.IsEnabled, Mode=TwoWay}"/>
      <cnc:NumericField Label="Arc resolution:" Unit="segments" Format="#0"
                        Value="{Binding GCodeViewer.ArcResolution, Mode=TwoWay}"/>
      <cnc:NumericField Label="Min distance:"
                        Value="{Binding GCodeViewer.MinDistance, Mode=TwoWay}"/>
      <cnc:NumericField Label="Tool diameter:" Unit="mm" Format="###0.0"
                        Value="{Binding GCodeViewer.ToolDiameter, Mode=TwoWay}"/>
      <CheckBox Content="Black background" FontSize="12" Margin="0,4,0,0"
                IsChecked="{Binding GCodeViewer.BlackBackground, Mode=TwoWay}"
                IsEnabled="{Binding GCodeViewer.IsEnabled}"/>
      <CheckBox Content="Show grid" FontSize="12" IsChecked="{Binding GCodeViewer.ShowGrid, Mode=TwoWay}"
                IsEnabled="{Binding GCodeViewer.IsEnabled}"/>
      <CheckBox Content="Show axes" FontSize="12" IsChecked="{Binding GCodeViewer.ShowAxes, Mode=TwoWay}"
                IsEnabled="{Binding GCodeViewer.IsEnabled}"/>
      <CheckBox Content="Show work envelope" FontSize="12"
                IsChecked="{Binding GCodeViewer.ShowWorkEnvelope, Mode=TwoWay}"
                IsEnabled="{Binding GCodeViewer.IsHomingEnabled}"/>
      <CheckBox Content="Show bounding box" FontSize="12"
                IsChecked="{Binding GCodeViewer.ShowBoundingBox, Mode=TwoWay}"
                IsEnabled="{Binding GCodeViewer.IsEnabled}"/>
      <CheckBox Content="Show ViewCube" FontSize="12" IsChecked="{Binding GCodeViewer.ShowViewCube, Mode=TwoWay}"
                IsEnabled="{Binding GCodeViewer.IsEnabled}"/>
      <CheckBox Content="Show coordinate system" FontSize="12"
                IsChecked="{Binding GCodeViewer.ShowCoordinateSystem, Mode=TwoWay}"
                IsEnabled="{Binding GCodeViewer.IsEnabled}"/>
      <CheckBox Content="Show text overlay" FontSize="12"
                IsChecked="{Binding GCodeViewer.ShowTextOverlay, Mode=TwoWay}"
                IsEnabled="{Binding GCodeViewer.IsEnabled}"/>
      <CheckBox Content="Auto scale tool" FontSize="12"
                IsChecked="{Binding GCodeViewer.ToolAutoScale, Mode=TwoWay}"
                IsEnabled="{Binding GCodeViewer.IsEnabled}"/>
      <CheckBox Content="Highlight completed cuts" FontSize="12"
                IsChecked="{Binding GCodeViewer.RenderExecuted, Mode=TwoWay}"
                IsEnabled="{Binding GCodeViewer.IsEnabled}"/>
    </WrapPanel>
  </GroupBox>
</UserControl>
