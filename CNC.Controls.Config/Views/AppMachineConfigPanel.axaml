<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cnc="using:CNC.Controls.Avalonia.Views"
             x:Class="CNC.Controls.Config.AppMachineConfigPanel"
             Classes="settings-panel">
  <GroupBox Header="Machine" Classes="form-section">
    <WrapPanel Classes="settings-form">
      <cnc:NumericField Classes="form-field" Label="Reset delay:" Unit="ms" Format="###0"
                        Value="{Binding ResetDelay, Mode=TwoWay}"/>
      <cnc:NumericField Classes="form-field" Label="Poll interval:" Unit="ms" Format="###0"
                        Value="{Binding PollInterval, Mode=TwoWay}"/>
      <cnc:NumericField Classes="form-field" Label="Max buffer:" Unit="bytes" Format="###0"
                        Value="{Binding MaxBufferSize, Mode=TwoWay}"/>
      <CheckBox Classes="form-option" Content="Aggressive buffering" IsChecked="{Binding UseBuffering, Mode=TwoWay}"
                ToolTip.Tip="Buffers more than one G-code block (grblHAL)."/>
      <CheckBox Classes="form-option" Content="Auto-compress gcode on transforms" IsChecked="{Binding AutoCompress, Mode=TwoWay}"/>
      <CheckBox Classes="form-option" Content="Send comments" IsChecked="{Binding SendComments, Mode=TwoWay}"/>
      <CheckBox Classes="form-option" Content="Add line numbers" IsChecked="{Binding AddLineNumbers, Mode=TwoWay}"/>
    </WrapPanel>
  </GroupBox>
</UserControl>
