<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CNC.Controls.Config.AppControllerConfigPanel"
             Width="420">
  <GroupBox Header="Controller bindings" BorderBrush="{DynamicResource ThemeBorderLowBrush}">
    <StackPanel Spacing="6">
      <CheckBox x:Name="EnabledBox" Content="Enable controller jogging"
                IsChecked="{Binding GameController.Enabled, Mode=TwoWay}"/>
      <TextBlock x:Name="StatusText" TextWrapping="Wrap" FontSize="11" Opacity="0.85"/>
      <ScrollViewer MaxHeight="360" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl x:Name="BindingsList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="150,110,*" Margin="0,2">
                <TextBlock Grid.Column="0" Text="{Binding ActionLabel}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding InputDisplay}" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="Capture" Tag="{Binding}" Click="OnCaptureClick"
                        MinWidth="80" HorizontalAlignment="Right"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
      <StackPanel Orientation="Horizontal" Spacing="6">
        <Button Content="Reset defaults" Click="OnResetDefaultsClick" MinWidth="110"/>
        <Button Content="Refresh status" Click="OnRefreshStatusClick" MinWidth="110"/>
      </StackPanel>
      <TextBlock x:Name="CaptureText" TextWrapping="Wrap" FontSize="11" Opacity="0.85"/>
    </StackPanel>
  </GroupBox>
</UserControl>
