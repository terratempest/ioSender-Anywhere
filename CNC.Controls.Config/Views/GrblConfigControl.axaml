<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="using:CNC.Core"
             xmlns:controls="using:CNC.Controls.Avalonia.Controls"
             xmlns:views="using:CNC.Controls.Avalonia.Views"
             mc:Ignorable="d"
             d:DesignHeight="480" d:DesignWidth="980"
             x:Class="CNC.Controls.Config.GrblConfigControl"
             Loaded="OnLoaded"
             SizeChanged="OnSizeChanged">

  <UserControl.DataTemplates>
    <TreeDataTemplate DataType="core:GrblSettingGroup" ItemsSource="{Binding Settings}">
      <TextBlock Text="{Binding Name}" FontSize="12"/>
    </TreeDataTemplate>
    <DataTemplate DataType="core:GrblSettingDetails">
      <StackPanel Orientation="Horizontal" Spacing="5">
        <TextBlock Text="{Binding Id}" FontSize="12"/>
        <TextBlock Text="{Binding Name, StringFormat='{}{0}:'}" FontSize="12"/>
        <TextBlock Text="{Binding FormattedValue}" FontSize="12"/>
        <TextBlock Text="{Binding Unit}" FontSize="12"/>
      </StackPanel>
    </DataTemplate>
  </UserControl.DataTemplates>

  <DockPanel>
    <Border Classes="ui-panel" DockPanel.Dock="Left" Width="400" Margin="10,10,0,10" Padding="6">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <views:NumericField x:Name="searchField" Classes="form-field" Grid.Row="0" Label="Setting:" Unit="" ToolTip.Tip="Search for setting (Enter)"
                            Format="###0" Margin="0,0,0,5" KeyDown="OnSearchKeyDown"/>
        <TreeView x:Name="treeView" Grid.Row="1" IsVisible="False" FontSize="12"
                  SelectionChanged="OnTreeSelectionChanged"
                  PointerReleased="OnTreePointerReleased"/>
        <DataGrid x:Name="dgrSettings" Grid.Row="1" IsReadOnly="True" FontSize="12"
                  SelectionMode="Single" AutoGenerateColumns="False"
                  CanUserReorderColumns="False" CanUserResizeColumns="False"
                  CanUserSortColumns="False"
                  SelectionChanged="OnGridSelectionChanged">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="70"/>
            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>

    <DockPanel Margin="10,10,10,0">
      <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="5" Margin="0,8,0,10">
        <Button x:Name="btnReload" Content="Reload" Width="90" HorizontalContentAlignment="Center" Click="OnReloadClick"
                ToolTip.Tip="Reload settings from controller."/>
        <Button x:Name="btnSave" Content="Save" Width="90" HorizontalContentAlignment="Center" Click="OnSaveClick"
                ToolTip.Tip="Save changed settings to controller."/>
        <Border HorizontalAlignment="Stretch" MinWidth="20"/>
        <Button x:Name="btnBackup" Content="Backup" Width="90" HorizontalContentAlignment="Center" Click="OnBackupClick"/>
        <Button x:Name="btnRestore" Content="Restore" Width="90" HorizontalContentAlignment="Center" Click="OnRestoreClick"/>
      </StackPanel>

      <Grid x:Name="details" DockPanel.Dock="Top" RowDefinitions="Auto,*,Auto" RowSpacing="6">
        <TextBlock x:Name="txtSettingTitle" Grid.Row="0" FontWeight="SemiBold" FontSize="12"/>
        <TextBox x:Name="txtValue" Classes="input-standard" Grid.Row="1" Width="200" HorizontalAlignment="Left" VerticalAlignment="Top"
                 FontSize="12"
                 controls:PopupKeyboard.Layout="Numeric"
                 LostFocus="OnValueLostFocus"/>
        <WrapPanel x:Name="valueEditorPanel" Grid.Row="1" Orientation="Vertical"
                   ItemWidth="180" MinHeight="40" IsVisible="False"/>
        <TextBox x:Name="txtDescription" Grid.Row="2" IsReadOnly="True" TextWrapping="Wrap"
                 AcceptsReturn="True" MinHeight="140" FontSize="12"/>
      </Grid>
    </DockPanel>
  </DockPanel>
</UserControl>
