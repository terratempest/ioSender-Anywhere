<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Soft dark / light palette overrides for FluentTheme (reduces harsh black/white contrast). -->
  <ResourceDictionary.ThemeDictionaries>
  <ResourceDictionary x:Key="Dark">
    <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ThemeForegroundBrush" Color="#D4D4D4"/>
    <SolidColorBrush x:Key="ThemeControlLowBrush" Color="#252526"/>
    <SolidColorBrush x:Key="ThemeControlMidBrush" Color="#2D2D30"/>
    <SolidColorBrush x:Key="ThemeControlHighBrush" Color="#3C3C3C"/>
    <SolidColorBrush x:Key="ThemeControlHighlightLowBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="ThemeControlHighlightMidBrush" Color="#454545"/>
    <SolidColorBrush x:Key="ThemeControlHighlightHighBrush" Color="#505050"/>
    <SolidColorBrush x:Key="ThemeBorderLowBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="ThemeBorderMidBrush" Color="#505050"/>
    <SolidColorBrush x:Key="ThemeBorderHighBrush" Color="#6A6A6A"/>
    <SolidColorBrush x:Key="ThemeAccentBrush" Color="#3794FF"/>
    <SolidColorBrush x:Key="ThemeAccentBrushLow" Color="#264F78"/>
    <SolidColorBrush x:Key="ThemeAccentBrushHigh" Color="#4DA3FF"/>
    <Color x:Key="ThemeAccentColor">#3794FF</Color>
    <Color x:Key="ThemeAccentColor1">#3794FF</Color>
    <Color x:Key="ThemeAccentColor2">#264F78</Color>
    <Color x:Key="ThemeAccentColor3">#4DA3FF</Color>
    <SolidColorBrush x:Key="IoSenderReadOnlyBrush" Color="#2A2A2E"/>
    <SolidColorBrush x:Key="IoSenderOverlayBrush" Color="#99000000"/>
    <SolidColorBrush x:Key="IoSenderDangerBrush" Color="#C62828"/>
    <SolidColorBrush x:Key="IoSenderDangerForegroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="IoSenderHomedBrush" Color="#2E7D32"/>
    <SolidColorBrush x:Key="IoSenderNotHomedBrush" Color="#B71C1C"/>
    <SolidColorBrush x:Key="IoSenderDroReadoutBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="IoSenderDroReadoutForegroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="IoSenderJogSelectedBrush" Color="#90EE90"/>
    <Color x:Key="IoSenderViewerBackgroundColor">#101010</Color>
    <Color x:Key="IoSenderViewerCutColor">#C95656</Color>
    <Color x:Key="IoSenderViewerRapidColor">#F4A6B2</Color>
    <Color x:Key="IoSenderViewerRetractColor">#4CAF50</Color>
    <Color x:Key="IoSenderViewerGridColor">#6A6A6A</Color>
    <Color x:Key="IoSenderViewerGridMinorColor">#353535</Color>
    <Color x:Key="IoSenderViewerGridMajorColor">#6A6A6A</Color>
    <Color x:Key="IoSenderViewerHighlightColor">#481E1E</Color>
    <Color x:Key="IoSenderViewerToolColor">#EE9D24</Color>
    <Color x:Key="IoSenderViewerWorkEnvelopeColor">#4DA3FF</Color>
  </ResourceDictionary>

  <ResourceDictionary x:Key="Light">
    <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#D9DDE1"/>
    <SolidColorBrush x:Key="ThemeForegroundBrush" Color="#343A42"/>
    <SolidColorBrush x:Key="ThemeControlLowBrush" Color="#C6C9CC"/>
    <SolidColorBrush x:Key="ThemeControlMidBrush" Color="#B5B9BD"/>
    <SolidColorBrush x:Key="ThemeControlHighBrush" Color="#D3DAE2"/>
    <SolidColorBrush x:Key="ThemeControlHighlightLowBrush" Color="#BBC3CB"/>
    <SolidColorBrush x:Key="ThemeControlHighlightMidBrush" Color="#B0BAC4"/>
    <SolidColorBrush x:Key="ThemeControlHighlightHighBrush" Color="#A4AFBA"/>
    <SolidColorBrush x:Key="ThemeBorderLowBrush" Color="#B9C1CA"/>
    <SolidColorBrush x:Key="ThemeBorderMidBrush" Color="#A5AFBA"/>
    <SolidColorBrush x:Key="ThemeBorderHighBrush" Color="#8F9AA6"/>
    <SolidColorBrush x:Key="ThemeAccentBrush" Color="#3A718F"/>
    <SolidColorBrush x:Key="ThemeAccentBrushLow" Color="#C1D5DF"/>
    <SolidColorBrush x:Key="ThemeAccentBrushHigh" Color="#2F5F79"/>
    <Color x:Key="ThemeAccentColor">#3A718F</Color>
    <Color x:Key="ThemeAccentColor1">#3A718F</Color>
    <Color x:Key="ThemeAccentColor2">#C1D5DF</Color>
    <Color x:Key="ThemeAccentColor3">#2F5F79</Color>
    <SolidColorBrush x:Key="IoSenderReadOnlyBrush" Color="#CDD3D9"/>
    <SolidColorBrush x:Key="IoSenderOverlayBrush" Color="#55000000"/>
    <SolidColorBrush x:Key="IoSenderDangerBrush" Color="#A14B47"/>
    <SolidColorBrush x:Key="IoSenderDangerForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="IoSenderHomedBrush" Color="#ABC9AE"/>
    <SolidColorBrush x:Key="IoSenderNotHomedBrush" Color="#D8B0B3"/>
    <SolidColorBrush x:Key="IoSenderDroReadoutBrush" Color="#EEF1F3"/>
    <SolidColorBrush x:Key="IoSenderDroReadoutForegroundBrush" Color="#2D3136"/>
    <SolidColorBrush x:Key="IoSenderJogSelectedBrush" Color="#6F9A76"/>
    <Color x:Key="IoSenderViewerBackgroundColor">#DDE2E6</Color>
    <Color x:Key="IoSenderViewerCutColor">#902A2A</Color>
    <Color x:Key="IoSenderViewerRapidColor">#3A9EB2</Color>
    <Color x:Key="IoSenderViewerRetractColor">#2F6138</Color>
    <Color x:Key="IoSenderViewerGridColor">#111111</Color>
    <Color x:Key="IoSenderViewerGridMinorColor">#B5BFC9</Color>
    <Color x:Key="IoSenderViewerGridMajorColor">#111111</Color>
    <Color x:Key="IoSenderViewerHighlightColor">#E4D3D3</Color>
    <Color x:Key="IoSenderViewerToolColor">#BC811C</Color>
    <Color x:Key="IoSenderViewerWorkEnvelopeColor">#294E73</Color>
  </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
