<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="using:CNC.Localization.Avalonia"
             mc:Ignorable="d" d:DesignWidth="230" d:DesignHeight="64"
             x:Class="CNC.Controls.Avalonia.Views.JobControl"
             Loaded="OnLoaded"
             SizeChanged="OnSizeChanged">

  <Grid x:Name="BtnGrid" RowDefinitions="*,6,*,6,*,6,*" Margin="4,4">
    <Button x:Name="BtnStart" Grid.Row="0" Classes="job-transport" Content="Cycle Start" Click="OnCycleStartClick"
            loc:Localize.Key="CNC.Controls.Avalonia.jobcontrol.btn_cycleStart"/>
    <Button x:Name="BtnHold" Grid.Row="2" Classes="job-transport" Content="Feed Hold" Click="OnFeedHoldClick"
            loc:Localize.Key="CNC.Controls.Avalonia.jobcontrol.btn_feedHold"/>
    <Button x:Name="BtnStop" Grid.Row="4" Classes="job-transport" Content="Stop" Click="OnStopClick"
            loc:Localize.Key="CNC.Controls.Avalonia.jobcontrol.btn_stop"/>
    <Button x:Name="BtnRewind" Grid.Row="6" Classes="job-transport" Content="Rewind" Click="OnRewindClick"
            loc:Localize.Key="CNC.Controls.Avalonia.jobcontrol.btn_rewind"/>
  </Grid>
</UserControl>
